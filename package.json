{
  "name": "phantomllm",
  "version": "1.0.0",
  "description": "Mock server for OpenAI-compatible APIs. Test your LLM integrations with a real HTTP server.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:sdk": "vitest run --project sdk",
    "test:bench": "vitest run --project bench",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@types/node": "^22.15.0",
    "ai": "^6.0.134",
    "openai": "^6.32.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/galElmalah/phantomllm.git"
  },
  "keywords": [
    "openai",
    "mock",
    "testing",
    "llm",
    "ai-sdk"
  ]
}
